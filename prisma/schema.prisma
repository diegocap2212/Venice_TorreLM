generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  password            String?
  name                String?
  role                String   @default("BP_ADMIN")
  password_changed_at DateTime?
  created_at          DateTime @default(now())
  vagas_criadas       Vaga[]   @relation("CriadorVaga")
  vagas_atuais        Vaga[]   @relation("ResponsavelVaga")
}

model Vaga {
  id                        String                @id @default(uuid())
  titulo                    String
  perfil_tipo               String
  senioridade               String
  aba_atual                 String                @default("RECRUTAMENTO")
  etapa_atual               String                @default("REQUISICAO")
  urgencia                  String                @default("NORMAL")
  squad_destino             String
  data_abertura             DateTime              @default(now())
  data_etapa_atual          DateTime              @default(now())
  sla_dias                  Int                   @default(3)
  briefing_handoff          String?
  bizneo_link               String?
  colaborador_contratado_id String?
  responsavel_id            String
  criado_por_id             String
  updated_at                DateTime              @updatedAt
  checklist_items           ChecklistItemStatus[]
  criado_por                User                  @relation("CriadorVaga", fields: [criado_por_id], references: [id])
  responsavel               User                  @relation("ResponsavelVaga", fields: [responsavel_id], references: [id])
  candidatos                VagaCandidato[]
}

model Candidato {
  id          String          @id @default(uuid())
  nome        String
  cpf_hash    String?         @unique
  cpf_masked  String?
  telefone    String?
  email       String?
  linkedin    String?
  status_cpf  String          @default("PENDENTE")
  observacoes String?
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt
  vagas       VagaCandidato[]
}

model VagaCandidato {
  id           String    @id @default(uuid())
  vaga_id      String
  candidato_id String
  status       String    @default("EM_PROCESSO")
  created_at   DateTime  @default(now())
  candidato    Candidato @relation(fields: [candidato_id], references: [id], onDelete: Cascade)
  vaga         Vaga      @relation(fields: [vaga_id], references: [id], onDelete: Cascade)

  @@unique([vaga_id, candidato_id])
}

model ChecklistItemStatus {
  id         String   @id @default(uuid())
  vaga_id    String
  etapa      String
  item_index Int
  concluido  Boolean  @default(false)
  updated_at DateTime @updatedAt
  vaga       Vaga     @relation(fields: [vaga_id], references: [id], onDelete: Cascade)

  @@unique([vaga_id, etapa, item_index])
}

model Colaborador {
  id                   String             @id @default(uuid())
  nome                 String
  cargo                String
  status               String             @default("Ativo")
  data_admissao        DateTime
  data_nascimento      DateTime
  torre                String?
  squad                String?
  email                String?
  cpf_hash             String?            @unique
  cpf_masked           String?
  telefone             String?
  linkedin             String?
  vaga_origem_id       String?
  data_desligamento    DateTime?
  motivo_desligamento  String?
  tipo_contrato        String?
  regime               String?
  salario              Float?
  centro_custo         String?
  informacoes_internas String?
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  ciclos_performance   CicloPerformance[]
  follow_ups           FollowUp[]
  horas_extras         HoraExtra[]
}

model FollowUp {
  id             String      @id @default(uuid())
  colaborador_id String
  tipo           String
  data_prevista  DateTime
  data_realizado DateTime?
  status         String      @default("PENDENTE")
  notas          String?
  created_at     DateTime    @default(now())
  colaborador    Colaborador @relation(fields: [colaborador_id], references: [id], onDelete: Cascade)
}

model HoraExtra {
  id             String      @id @default(uuid())
  colaborador_id String
  mes_referencia String
  horas          Float
  status         String      @default("PENDENTE")
  observacao     String?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  colaborador    Colaborador @relation(fields: [colaborador_id], references: [id], onDelete: Cascade)

  @@unique([colaborador_id, mes_referencia])
}

model CicloPerformance {
  id             String      @id @default(uuid())
  colaborador_id String
  periodo        String
  tipo           String
  status         String      @default("PENDENTE")
  data_prevista  DateTime
  data_realizado DateTime?
  conteudo       Json?
  responsavel    String      @default("BP")
  created_at     DateTime    @default(now())
  colaborador    Colaborador @relation(fields: [colaborador_id], references: [id], onDelete: Cascade)

  @@unique([colaborador_id, periodo, tipo])
}

model AuditLog {
  id         String   @id @default(uuid())
  user_email String
  acao       String
  recurso    String
  recurso_id String?
  detalhes   String?
  ip         String?
  created_at DateTime @default(now())

  @@map("audit_logs")
}

model SyncRun {
  id                 String   @id @default(uuid())
  status             String   @default("PENDING") // PENDING, RUNNING, SUCCESS, PARTIAL, FAILED
  started_at         DateTime @default(now())
  completed_at       DateTime?
  duration_ms        Int?
  total_processed    Int      @default(0)
  total_created      Int      @default(0)
  total_updated      Int      @default(0)
  total_skipped      Int      @default(0)
  error_count        Int      @default(0)
  error_details      String?  // JSON array of errors
  idempotency_key    String   @unique // Para garantir idempotência
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@index([status])
  @@index([started_at])
  @@map("sync_runs")
}

model SyncLock {
  id            String   @id @default(uuid())
  lock_key      String   @unique // "sharepoint_sync"
  acquired_at   DateTime @default(now())
  expires_at    DateTime // Timeout para evitar deadlock
  acquired_by   String   // Instance ID do servidor
  is_active     Boolean  @default(true)
  updated_at    DateTime @updatedAt

  @@map("sync_locks")
}

model SyncMetrics {
  id                      String   @id @default(uuid())
  total_runs              Int      @default(0)
  successful_runs         Int      @default(0)
  failed_runs             Int      @default(0)
  total_records_processed Int      @default(0)
  total_created           Int      @default(0)
  total_updated           Int      @default(0)
  total_skipped           Int      @default(0)
  avg_duration_ms         Int      @default(0)
  last_sync_at            DateTime?
  updated_at              DateTime @updatedAt

  @@map("sync_metrics")
}

model Material {
  id          String   @id @default(uuid())
  titulo      String
  descricao   String?
  url         String
  tipo        String   @default("Apresentação")
  data_upload DateTime @default(now())
  created_at  DateTime @default(now())
}

model WowReport {
  id          String   @id @default(uuid())
  sm          String
  squad       String
  date        String
  cone        Boolean?
  coneText    String?  @map("cone_text")
  pdti        Boolean?
  pdtiText    String?  @map("pdti_text")
  parado      Boolean?
  paradoText  String?  @map("parado_text")
  wipEpic     Boolean?
  wipEpicText String?  @map("wip_epic_text")
  wipUs       Boolean?
  wipUsText   String?  @map("wip_us_text")
  oQue        String?  @map("o_que")
  problemas   String?
  acoes       String?
  images      Json?
  created_at  DateTime @default(now())

  @@map("wow_reports")
}

model WowWeeklyReport {
  id         String   @id @default(uuid())
  sm         String
  week       String
  q1         String?
  q2         String?
  q3         String?
  q4         String?
  created_at DateTime @default(now())

  @@map("wow_weekly_reports")
}

model WowSquadReport {
  id         String   @id @default(uuid())
  sm         String
  squad      String
  week       String
  notes      String?
  q1         String?
  q2         String?
  q3         String?
  q4         String?
  created_at DateTime @default(now())

  @@unique([sm, squad, week])
  @@map("wow_squad_reports")
}

model WowSquadOverride {
  id         String   @id @default(uuid())
  sm         String
  squad      String
  week       String
  field      String
  value      Float
  created_at DateTime @default(now())

  @@unique([sm, squad, week, field])
  @@map("wow_squad_overrides")
}
